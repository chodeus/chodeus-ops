{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Chodeus shareable Renovate preset. Callers: { \"extends\": [\"github>chodeus/chodeus-ops\"] }",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    ":gitSignOff",
    "schedule:weekends",
    "group:allNonMajor"
  ],
  "timezone": "America/Los_Angeles",
  "labels": ["dependencies"],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "rangeStrategy": "bump",
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 5am on monday"]
  },
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"],
    "prPriority": 10
  },
  "packageRules": [
    {
      "description": "Auto-merge patch updates after CI passes",
      "matchUpdateTypes": ["patch", "pin", "digest"],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "description": "Group Python dev deps",
      "matchManagers": ["pip_requirements", "pip_setup", "pyproject"],
      "matchDepTypes": ["devDependencies"],
      "groupName": "python-dev"
    },
    {
      "description": "Group GitHub Actions",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions",
      "pinDigests": true
    },
    {
      "description": "Docker base images — separate PRs so breakage is isolated",
      "matchManagers": ["dockerfile", "docker-compose"],
      "matchUpdateTypes": ["major"],
      "groupName": null,
      "labels": ["dependencies", "docker", "major"]
    },
    {
      "description": "Pin all GitHub Actions to SHAs",
      "matchManagers": ["github-actions"],
      "pinDigests": true
    }
  ],
  "dockerfile": {
    "pinDigests": true
  },
  "docker-compose": {
    "pinDigests": true
  },
  "osvVulnerabilityAlerts": true,
  "separateMinorPatch": true
}
